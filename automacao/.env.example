# ================================================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA COM SEUS VALORES REAIS
# cp .env.example .env
# ================================================================

# IP público do seu Droplet (preencher após criar o servidor)
SERVER_IP=SEU_IP_AQUI

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=vf_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
POSTGRES_DB=vf_financeiro

# ── Evolution API ───────────────────────────────────────────────
# Chave de acesso da API — gere uma senha forte (ex: openssl rand -hex 32)
EVOLUTION_API_KEY=TROQUE_POR_CHAVE_FORTE_AQUI

# ── N8N ─────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
